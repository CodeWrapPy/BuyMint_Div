# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
DATABASE_URL=sqlite:///buymint.db

# ── Google OAuth ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorised redirect URI: http://localhost:5000/api/auth/google/callback
# 5. Paste the values below
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxx

# ── Apple Sign In ─────────────────────────────────────────────
# Requires Apple Developer account ($99/yr) at developer.apple.com
#
# Steps:
# 1. Identifiers → register an App ID (enable "Sign In with Apple")
# 2. Identifiers → register a Services ID (this is your APPLE_CLIENT_ID)
#    Set the Return URL to: https://yourdomain.com/api/auth/apple/callback
# 3. Keys → create a key, enable "Sign In with Apple", download .p8 file
#
APPLE_CLIENT_ID=com.yourdomain.buymint       # Your Services ID
APPLE_TEAM_ID=XXXXXXXXXX                     # 10-char Team ID from developer.apple.com
APPLE_KEY_ID=XXXXXXXXXX                      # 10-char Key ID shown after creating the key
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8   # path to downloaded .p8 file

# ── Twilio SMS ───────────────────────────────────────────────
# Leave blank to disable SMS — contact enquiries still save to DB.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+12015551234
OWNER_PHONE_NUMBER=+919876543210
